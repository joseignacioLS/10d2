---
import { Font } from "astro:assets";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>10d2</title>
		<Font cssVariable="--font-open-sans" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--night-sky: #060610;
		--egg-shell: #eeeedd;
	}

	html {
		background-color: var(--egg-shell);
		color: var(--night-sky);
		font-family: var(--font-open-sans);
	}

	@media (prefers-color-scheme: dark) {
		html {
			background-color: var(--night-sky);
			color: var(--egg-shell);
		}
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;

		color: inherit;
		font-family: inherit;
	}

	html,
	body {
		min-height: 100dvh;
		min-width: 100dvw;
		width: 100%;
		height: 100%;
		margin: 0;
	}

	body {
		max-width: 70ch;
		margin: auto;
	}

	header {
		width: 100%;
		margin: auto;
		h1 {
			text-align: center;
		}
	}
</style>
