---
import { Font } from "astro:assets";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>10d2</title>
		<Font cssVariable="--font-open-sans" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--night-sky: #060610;
		--egg-shell: #eeeedd;

		--main-bg-color: var(--egg-shell);
		--main-fg-color: var(--night-sky);
	}

	:root {
		interpolate-size: allow-keywords;
		/* 👈 */
	}
	@media (prefers-color-scheme: dark) {
		:root {
			--main-bg-color: var(--night-sky);
			--main-fg-color: var(--egg-shell);
		}
	}

	html {
		background-color: var(--main-bg-color);
		color: var(--main-fg-color);
		font-family: var(--font-open-sans);
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;

		color: inherit;
		font-family: inherit;
	}

	html,
	body {
		min-height: 100dvh;
		width: 100%;
		height: 100%;
		margin: 0;
	}

	body {
		max-width: 70ch;
		margin: auto;

		&:has(.backdrop) {
			overflow: hidden;
		}
	}

	header {
		width: 100%;
		margin: auto;
		h1 {
			text-align: center;
		}
	}

	main {
		padding: 0 16px;
	}
</style>
